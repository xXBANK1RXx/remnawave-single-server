# .env.example

# This is an example of environment variables configuration.

# Database connection settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=your_database_name_here

# API settings
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Other settings
ENV=development
